@page "/"
@inject RestaurantOptions Options

<PageTitle>@Options.RestaurantName</PageTitle>

<section class="landing">
    <p class="eyebrow">Ordering system</p>
    <h1 class="landing-title">@Options.RestaurantName</h1>

    <p class="landing-lede">
        The application shell is running. The Milestone&nbsp;1 skeleton (domain, data access, web
        host, startup migrations) is in place, and Milestone&nbsp;2 is under way: password sign-in
        with the TOTP/recovery challenge, lockout, and the forced-password-change pipeline work now.
        Guest ordering, the kitchen and counter boards, and administration arrive in later
        milestones.
    </p>

    <dl class="facts">
        <div class="fact">
            <dt>Time zone</dt>
            <dd>@Options.TimeZoneId</dd>
        </div>
        <div class="fact">
            <dt>Currency</dt>
            <dd>@Options.CurrencyCode</dd>
        </div>
    </dl>

    <nav class="health-links" aria-label="Health checks and areas">
        <a href="/healthz/live">Liveness</a>
        <a href="/healthz/ready">Readiness</a>
        <a href="/table">Table area (sign-in required)</a>
    </nav>
</section>
