@page "/"
@inject RestaurantOptions Options

<PageTitle>@Options.RestaurantName</PageTitle>

<section class="landing">
    <p class="eyebrow">Ordering system</p>
    <h1 class="landing-title">@Options.RestaurantName</h1>

    <p class="landing-lede">
        The application shell is running. This is the Milestone&nbsp;1 skeleton: the domain,
        data-access, and web host are in place, and the database schema is applied at startup.
        Guest, kitchen, counter, and administrator experiences arrive in later milestones.
    </p>

    <dl class="facts">
        <div class="fact">
            <dt>Time zone</dt>
            <dd>@Options.TimeZoneId</dd>
        </div>
        <div class="fact">
            <dt>Currency</dt>
            <dd>@Options.CurrencyCode</dd>
        </div>
    </dl>

    <nav class="health-links" aria-label="Health checks">
        <a href="/healthz/live">Liveness</a>
        <a href="/healthz/ready">Readiness</a>
    </nav>
</section>
