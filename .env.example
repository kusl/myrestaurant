# Copy to `.env` and adjust. `.env` is git-ignored; never commit a populated one.
# Configuration is environment-only (TECHNICAL_SPECIFICATION §13). Every value here has a safe dev
# default in the app; the ones marked "PRODUCTION: change" MUST be overridden before going live.

# --- Identity & origin ---------------------------------------------------------------------------
RESTAURANT_NAME=My Restaurant
# The canonical origin for QR/link URLs and the fallback for the WebAuthn RP ID. Dev uses Caddy on
# 8443; production is your Cloudflare named-tunnel hostname (a stable domain so passkeys persist).
# PRODUCTION: change (must be an https URL). The RP ID is derived per request from the host the
# browser is on (ADR-0005), so a quick tunnel's per-run *.trycloudflare.com host works too — this
# value is the fallback when a request carries no trusted Origin header.
RESTAURANT_PUBLIC_ORIGIN=https://localhost:8443
# Wildcard origins (besides RESTAURANT_PUBLIC_ORIGIN and loopback) allowed to act as the WebAuthn
# relying party (ADR-0005, §3.3). Comma/space/newline separated; each is scheme://host with an
# optional single leading "*." label, https, no path or port. The default trusts Cloudflare quick
# tunnels so `scripts/quick_tunnel.sh` demos work with passkeys out of the box; clear it (set to a
# single space) to lock passkeys to RESTAURANT_PUBLIC_ORIGIN only.
RESTAURANT_TRUSTED_ORIGIN_PATTERNS=https://*.trycloudflare.com
RESTAURANT_TIME_ZONE=America/New_York
RESTAURANT_CURRENCY_CODE=USD

# --- Database ------------------------------------------------------------------------------------
# Consumed by the postgres container. PRODUCTION: change POSTGRES_PASSWORD.
POSTGRES_USER=myrestaurant
POSTGRES_PASSWORD=myrestaurant
POSTGRES_DB=myrestaurant
# The app's own connection string. In compose this is derived from the POSTGRES_* values above and
# points at the `postgres` service; only set this if you are pointing at an external database.
# RESTAURANT_DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=myrestaurant;Username=myrestaurant;Password=myrestaurant

# --- Data protection keys (§3.4) -----------------------------------------------------------------
# A named volume in compose; back it up alongside the database or TOTP secrets/cookies are lost.
DATA_PROTECTION_KEYS_DIRECTORY=/var/lib/myrestaurant/dataprotection

# --- Timing knobs --------------------------------------------------------------------------------
KITCHEN_SUBMISSION_REMINDER_SECONDS=60   # §10.2, min 1
TABLE_JOIN_TOKEN_ROTATION_SECONDS=60     # §4.3, min 10
TABLE_JOIN_GRANT_MINUTES=10              # §4.4, min 1
TABLE_DISPLAY_PAIRING_CODE_MINUTES=10    # §4.2, min 1

# --- Argon2id (§3.2 + startup floor guard) -------------------------------------------------------
# The app refuses to start below the floor: memory >= 19456 KiB, iterations >= 2, parallelism >= 1.
ARGON2_MEMORY_KIBIBYTES=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=1
ARGON2_MAX_CONCURRENT_HASHES=4

# --- Backups (§15) -------------------------------------------------------------------------------
BACKUP_DIRECTORY=/var/lib/myrestaurant/backups
BACKUP_SCHEDULE_TIME=03:30
BACKUP_RETENTION_COUNT=14

# --- OpenTelemetry (optional, §12) ---------------------------------------------------------------
# Unset by default; when unset the app attaches no OTLP exporter (no connection-refused noise).
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>
OTEL_SERVICE_NAME=myrestaurant
# run.sh also accepts a legacy UPTRACE_DSN and translates it into the OTEL_* variables above.
# UPTRACE_DSN=

# --- Production tunnel (production profile only, §14.1) ------------------------------------------
# PRODUCTION: set to your Cloudflare named-tunnel token. Required by `--profile production`.
# CLOUDFLARE_TUNNEL_TOKEN=
